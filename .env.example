# Copy to .env and fill in. Both are OPTIONAL — the pipeline runs fully offline
# using the synthetic CSV and a deterministic report when these are unset.

# Enables the LLM-written weekly narrative (CommsAgent) and row enrichment.
ANTHROPIC_API_KEY=

# Enables live catalog fetch from the RAWG public API. Falls back to
# data/synthetic_games.csv when unset or unreachable.
RAWG_API_KEY=
